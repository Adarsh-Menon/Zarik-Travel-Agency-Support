</span></span><span><span class="token token table table-data-rows"></span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> budget </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> string </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> Budget with currency </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows">
</span></span><span><span class="token token table table-data-rows"></span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> group_size </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> int </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> Number of travelers </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows">
</span></span><span><span class="token token table table-data-rows"></span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> interests </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> string </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> Comma-separated </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows">
</span></span><span><span class="token token table table-data-rows"></span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> status </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> string </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> New / Contacted / Converted / Lost </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows">
</span></span><span><span class="token token table table-data-rows"></span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> itinerary_summary </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> string </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> Brief trip description </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows">
</span></span><span><span class="token token table table-data-rows"></span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> created_at </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> datetime </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> First interaction </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows">
</span></span><span><span class="token token table table-data-rows"></span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> last_updated </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> datetime </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> Last modification </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows">
</span></span><span><span class="token token table table-data-rows"></span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> notes </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> string </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows table-data"> Agent/admin notes </span><span class="token token table table-data-rows" style="color: rgb(211, 215, 222);">|</span><span class="token token table table-data-rows">
</span></span><span><span class="token token table table-data-rows"></span><span>
</span></span><span><span></span><span class="token token title" style="color: rgb(211, 215, 222); font-weight: bold;">##</span><span class="token token title" style="color: rgb(244, 123, 133); font-weight: bold;"> Status Colors</span><span>
</span></span><span>
</span><span><span></span><span class="token token list" style="color: rgb(211, 215, 222);">-</span><span> 🔵 </span><span class="token token bold" style="color: rgb(211, 215, 222);">**</span><span class="token token bold content">New</span><span class="token token bold" style="color: rgb(211, 215, 222);">**</span><span> — just captured
</span></span><span><span></span><span class="token token list" style="color: rgb(211, 215, 222);">-</span><span> 🟡 </span><span class="token token bold" style="color: rgb(211, 215, 222);">**</span><span class="token token bold content">Contacted</span><span class="token token bold" style="color: rgb(211, 215, 222);">**</span><span> — itinerary generated
</span></span><span><span></span><span class="token token list" style="color: rgb(211, 215, 222);">-</span><span> 🟢 </span><span class="token token bold" style="color: rgb(211, 215, 222);">**</span><span class="token token bold content">Converted</span><span class="token token bold" style="color: rgb(211, 215, 222);">**</span><span> — booked
</span></span><span><span></span><span class="token token list" style="color: rgb(211, 215, 222);">-</span><span> 🔴 </span><span class="token token bold" style="color: rgb(211, 215, 222);">**</span><span class="token token bold content">Lost</span><span class="token token bold" style="color: rgb(211, 215, 222);">**</span><span> — didn't convert
</span></span><span>
</span><span><span></span><span class="token token title" style="color: rgb(211, 215, 222); font-weight: bold;">##</span><span class="token token title" style="color: rgb(244, 123, 133); font-weight: bold;"> API Endpoints</span></span></code></pre></div></div>
<p class="font-claude-response-body break-words whitespace-pre-wrap leading-[1.7]">GET    /api/leads              — list all leads
GET    /api/leads?status=New   — filter by status
GET    /api/leads/stats        — count by status
GET    /api/leads/{id}         — get one lead
PATCH  /api/leads/{id}         — update status/notes</p>
