# Zarik Environment Variables
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile
TELEGRAM_BOT_TOKEN=your-bot-token-here
LEADS_EXCEL_PATH=data/leads.xlsx
MEMORY_DIR=data/memory
LOG_LEVEL=INFO
FASTAPI_PORT=8000

# Available Groq Models (pick one for GROQ_MODEL):
# llama-3.3-70b-versatile   — best quality, 128k context (recommended)
# llama-3.1-8b-instant      — fastest, good for collection phase
# mixtral-8x7b-32768        — solid alternative, 32k context
# gemma2-9b-it              — lightweight option
